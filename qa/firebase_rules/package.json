{
  "name": "chubbs-firebase-rules-tests",
  "version": "1.0.0",
  "private": true,
  "description": "Verifies the Realtime Database rules in database.rules.json allow/deny the right paths.",
  "scripts": {
    "test": "FIREBASE_DATABASE_EMULATOR_HOST=localhost:9000 mocha tests/**/*.spec.js --timeout 10000",
    "emulator": "firebase emulators:start --only database",
    "test:with-emulator": "firebase emulators:exec --only database 'mocha tests/**/*.spec.js --timeout 10000'"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "firebase-admin": "^13.0.0",
    "mocha": "^10.8.2"
  }
}
